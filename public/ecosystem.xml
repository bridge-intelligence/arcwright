  <!-- DATA PIPELINES (Kafka event flows)                                 -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <data-pipelines>
    <pipeline name="Custody → Ledger Settlement">
      <description>On-chain deposit confirmed → Ledger creates double-entry posting (debit external, credit user)</description>
      <flow>
        <step service="custody" action="Confirms on-chain deposit"/>
        <step topic="custody.domain.events" type="kafka"/>
        <step service="ledger" action="Consumes event, creates posting via inbox dedup"/>
        <step topic="ledger.domain.events" type="kafka"/>
      </flow>
    </pipeline>

    <pipeline name="Order Execution → Settlement">
      <description>Order submitted → hold requested → executed at venue → fill posted to ledger</description>
      <flow>
        <step service="orchestra" action="Submits order via HTTP"/>
        <step service="execution" action="Requests hold from Ledger"/>
        <step service="ledger" action="Creates hold (ACTIVE)"/>
        <step service="execution" action="Executes at venue, receives fill"/>
        <step topic="bridge.v1.execution.order.filled" type="kafka"/>
        <step service="ledger" action="Converts hold to posting, creates fee entry"/>
      </flow>
    </pipeline>

    <pipeline name="Market Data Distribution">
      <description>MarketData publishes prices → Portfolio caches → Wallet displays</description>
      <flow>
        <step service="marketdata" action="Polls venues, calculates mark/VWAP"/>
        <step topic="bridge.v1.market.price.mark" type="kafka"/>
        <step service="portfolio" action="Consumes prices → Redis cache"/>
        <step service="wallet" action="Queries portfolio API for valuations"/>
      </flow>
    </pipeline>

    <pipeline name="User Onboarding">
      <description>Wallet → Bridge-ID auth → Orchestra compliance → KYC verification</description>
      <flow>
        <step service="wallet" action="User clicks login/register"/>
        <step service="bridge-id" action="OIDC auth code + PKCE flow"/>
        <step service="orchestra" action="Starts onboarding workflow"/>
        <step service="orchestra" action="Compliance check (Sumsub/Onfido)"/>
        <step topic="bridge.v1.identity.*" type="kafka"/>
      </flow>
    </pipeline>

    <pipeline name="Fiat PKR Transfer">
      <description>Wallet → Orchestra → Bank Simulator (IBFT/RAAST) → Settlement webhook</description>
      <flow>
        <step service="wallet" action="User initiates PKR transfer"/>
        <step service="orchestra" action="Creates transfer workflow"/>
        <step service="bank-simulator" action="Processes IBFT/RAAST transfer"/>
        <step service="orchestra" action="Receives settlement webhook"/>
        <step service="ledger" action="Creates settlement posting"/>
      </flow>
    </pipeline>
  </data-pipelines>

