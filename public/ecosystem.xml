    <service id="execution" status="active">
      <name>Bridge Execution</name>
      <repo>bridge-execution-service</repo>
      <tech>Kotlin, Spring Boot 3, PostgreSQL, Kafka, Flyway</tech>
      <port app="8083" k8s="8080"/>
      <image>dev-5e5248c7</image>
      <url internal="http://bridge-execution-service.bridge-service-stack.svc.cluster.local:8080"/>
      <role>Order lifecycle: state machine (PENDING→HELD→EXECUTING→FILLED→SETTLED), hold protocol with Ledger, venue routing</role>
      <health endpoint="/actuator/health"/>
      <database type="postgresql" name="bridge_execution"/>
      <state-machine>
        <state name="PENDING" transitions="HOLD_REQUESTED"/>
        <state name="HOLD_REQUESTED" transitions="HELD, REJECTED"/>
        <state name="HELD" transitions="EXECUTING"/>
        <state name="EXECUTING" transitions="PARTIALLY_FILLED, FILLED, FAILED"/>
        <state name="PARTIALLY_FILLED" transitions="FILLED"/>
        <state name="FILLED" transitions="SETTLED"/>
        <state name="SETTLED" terminal="true"/>
        <state name="REJECTED" terminal="true"/>
        <state name="CANCELLED" terminal="true"/>
        <state name="FAILED" terminal="true"/>
      </state-machine>
      <components>
        <component name="Order State Machine" type="core">Enforces valid state transitions</component>
        <component name="Hold Coordinator" type="core">Manages hold protocol with Ledger</component>
        <component name="Venue Router" type="core">Pluggable venue adapters (Binance, etc.)</component>
        <component name="Inbox/Outbox" type="reliability">Exactly-once order processing</component>
      </components>
      <outbound-connections>
        <connection target="ledger" protocol="http" direction="two-way" data="Hold request → confirm/release"/>
        <connection target="postgresql" protocol="jdbc" direction="two-way" data="bridge_execution DB"/>
